# ===== Model / LLM =====
# OpenAI 兼容接口基础地址（必须包含 /v1）
OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
# 主对话模型名称（agent.py / wechat_robot_server.py 使用）
OPENROUTER_MODEL=your-model-name
# 单个 API Key（推荐）
OPENROUTER_API_KEY=your-openrouter-api-key
# 多个 API Key（逗号分隔，可轮询；不需要可留空）
OPENROUTER_API_KEYS=
# 模型连接失败重试次数
REACT_MODEL_CONNECT_RETRIES=2

# ===== ReAct runtime =====
# 单轮最大思考步数（超出会强制结束）
REACT_MAX_STEPS=12
# 注入给模型的历史消息上限
REACT_MAX_HISTORY_MESSAGES=20
# 记忆摘要保留的轮数上限
REACT_MAX_MEMORY_TURNS=8
# 每条记忆文本最大长度
REACT_MEMORY_TEXT_LIMIT=240
# 提示词中可注入的项目文件数量上限
REACT_PROMPT_MAX_FILES=30
# 每轮候选 skill shortlist 数量
SKILL_SHORTLIST_LIMIT=3

# ===== WeCom / HTTP server =====
# 企业微信机器人 Token
WECHAT_ROBOT_TOKEN=your-wechat-token
# 企业微信机器人 EncodingAESKey
WECHAT_ROBOT_ENCODING_AES_KEY=your-wechat-encoding-aes-key
# 企业微信接收方 ID（可为空，按你的企微配置填写）
WECHAT_ROBOT_RECEIVE_ID=
# 用户进入会话时的欢迎语
WECHAT_ROBOT_WELCOME_TEXT=欢迎进入智能助手。你可以直接提问，我会用流式消息回复你。
# 是否打印企微回复调试日志
WECHAT_REPLY_DEBUG_LOG=false
# 是否记录消息正文到日志（生产环境建议 false）
WECHAT_LOG_MESSAGE_CONTENT=false
# 处理消息的线程池大小
WECHAT_WORKER_MAX=8
# 单条消息最大处理秒数（软超时）
WECHAT_MAX_PROCESS_SECONDS=180
# 是否使用 waitress 启动（false 则使用 Flask 内置服务）
WECHAT_USE_WAITRESS=true
# HTTP 服务监听地址
WECHAT_SERVER_HOST=0.0.0.0
# HTTP 服务端口
WECHAT_SERVER_PORT=8085
# 日志级别：DEBUG/INFO/WARNING/ERROR
LOG_LEVEL=INFO

# ===== Session / conversation =====
# 会话实例在缓存中的存活秒数
SESSION_TTL_SECONDS=1800
# 流式结果状态存活秒数
STREAM_TTL_SECONDS=600
# 分布式会话锁存活秒数
SESSION_LOCK_TTL_SECONDS=180
# 每次加载历史消息的条数
CHAT_HISTORY_LOAD_LIMIT=10
# 消息保留天数（用于清理任务）
CHAT_MESSAGE_RETENTION_DAYS=90
# 会话无活动保留秒数（用于清理）
CHAT_SESSION_INACTIVE_RETENTION_SECONDS=21600
# 清理任务执行间隔秒数
CHAT_CLEANUP_INTERVAL_SECONDS=300
# 消息去重状态保留秒数
CHAT_MESSAGE_DEDUP_TTL_SECONDS=600

# ===== MySQL =====
# 是否启用 MySQL（企业微信服务当前实现依赖该存储）
MYSQL_ENABLED=true
# MySQL 主机
MYSQL_HOST=your-mysql-host
# MySQL 端口
MYSQL_PORT=3306
# MySQL 用户名
MYSQL_USER=your-mysql-user
# MySQL 密码
MYSQL_PASSWORD=your-mysql-password
# MySQL 数据库名
MYSQL_DATABASE=your-mysql-database
# MySQL 连接超时（秒）
MYSQL_CONNECT_TIMEOUT=3
# MySQL 连接池大小
MYSQL_POOL_SIZE=8

# ===== Redis (optional) =====
# 是否启用 Redis 缓存（不开启会自动降级到本地内存）
REDIS_ENABLED=false
# Redis key 前缀，避免多项目冲突
REDIS_KEY_PREFIX=agent_demo
# Redis 主机
REDIS_HOST=127.0.0.1
# Redis 端口
REDIS_PORT=6379
# Redis 数据库编号
REDIS_DB=0
# Redis 密码（无密码可留空）
REDIS_PASSWORD=
# Redis 读写超时（秒）
REDIS_SOCKET_TIMEOUT_SECONDS=2
# Redis 建连超时（秒）
REDIS_CONNECT_TIMEOUT_SECONDS=2

# ===== RAG =====
# 是否启用 RAG 工具（rag_summarize）
RAG_ENABLED=true
# 检索返回 chunk 数量
RAG_TOP_K=4
# 知识库原始文档目录
RAG_DATA_DIR=knowledge
# 向量库持久化目录
RAG_PERSIST_DIR=.rag_store
# Chroma collection 名称
RAG_COLLECTION_NAME=knowledge
# 文本切片长度
RAG_CHUNK_SIZE=700
# 文本切片重叠长度
RAG_CHUNK_OVERLAP=120
# 允许入库的文件类型（逗号分隔）
RAG_ALLOWED_TYPES=.txt,.md,.pdf
# 向量化模型名称
RAG_EMBEDDING_MODEL=text-embedding-v4
# RAG 总结使用的聊天模型（为空时回退 OPENROUTER_MODEL）
RAG_CHAT_MODEL=your-rag-chat-model

# ===== MCP =====
# 通过环境变量内联 MCP 配置（JSON 字符串，优先级高于配置文件）
MCP_SERVERS_JSON=
# MCP 配置文件路径（为空时默认 config/mcp_servers.json）
MCP_CONFIG_PATH=

# ===== Skill =====
# 是否允许执行 skill/scripts 下脚本
SKILL_ENABLE_SCRIPTS=false
# Skill 脚本执行超时（秒）
SKILL_SCRIPT_TIMEOUT_SECONDS=20
# Skill 脚本输出最大字符数（超出截断）
SKILL_SCRIPT_OUTPUT_LIMIT=4000
